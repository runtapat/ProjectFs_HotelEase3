<!DOCTYPE html>
<html lang="th">
<head>
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <style>
        .tab-btn { padding: 10px 20px; background: #ddd; border: none; cursor: pointer; font-size: 16px; font-weight: bold; border-radius: 8px 8px 0 0; }
        .tab-btn.active { background: var(--primary); color: white; }
        .tab-content { display: none; background: white; padding: 20px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); border-radius: 0 8px 8px 8px; }
        .form-row { display: flex; gap: 10px; margin-bottom: 10px; }
        .form-row input, .form-row select { flex: 1; padding: 10px; border: 1px solid #ccc; border-radius: 4px; }
        .badge { padding: 4px 8px; border-radius: 4px; font-weight: bold; font-size: 12px; }
        .bg-pending { background: #febb02; color: #333; }
        .bg-confirmed { background: #28a745; color: white; }
        .bg-cancelled { background: #dc3545; color: white; }
    </style>
</head>
<body>
    <nav><h2 style="margin: 0; color: var(--secondary);">Admin System</h2><button class="btn btn-danger" onclick="localStorage.clear(); window.location.href='/login'">ออกจากระบบ</button></nav>

    <div class="container">
        <div style="display: flex; gap: 5px; margin-top: 20px;">
            <button class="tab-btn active" onclick="switchTab('bookings', this)">รายการจอง</button>
            <button class="tab-btn" onclick="switchTab('hotels', this)">จัดการโรงแรม</button>
            <button class="tab-btn" onclick="switchTab('rooms', this)">จัดการห้องพัก</button>
        </div>

        <div id="bookings" class="tab-content" style="display: block;">
            <h3>รายการจองทั้งหมด</h3>
            <div style="overflow-x: auto;">
                <table>
                    <thead><tr><th>ID</th><th>ลูกค้า</th><th>โรงแรม (ห้อง)</th><th>วันที่</th><th>ยอดรวม</th><th>สถานะ</th><th>จัดการ</th></tr></thead>
                    <tbody id="tb-bookings"></tbody>
                </table>
            </div>
        </div>

        <div id="hotels" class="tab-content">
            <div style="background: #f9f9f9; padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #ddd;">
                <h4 id="h-title" style="margin-top:0; color:var(--primary);">➕ เพิ่ม/แก้ไข โรงแรม</h4>
                <input type="hidden" id="edit-h-id">
                <div class="form-row"><input type="text" id="h-name" placeholder="ชื่อโรงแรม"><input type="text" id="h-loc" placeholder="ที่ตั้ง"></div>
                
                <div class="form-row">
                    <input type="number" step="0.1" min="0" max="10" id="h-rating" placeholder="เรตติ้ง (สูงสุด 10)" oninput="if(this.value > 10) this.value = 10; if(this.value < 0) this.value = 0;">
                    <input type="text" id="h-img" placeholder="URL รูปภาพ">
                </div>
                
                <div class="form-row"><input type="text" id="h-desc" placeholder="คำอธิบายโรงแรม" style="flex:1;"></div>
                <button class="btn btn-success" id="btn-save-h" onclick="saveHotel()">บันทึกโรงแรม</button>
                <button class="btn" style="display:none; background:#666;" id="btn-cancel-h" onclick="resetHotelForm()">ยกเลิกการแก้ไข</button>
            </div>
            <table>
                <thead><tr><th>ID</th><th>ชื่อโรงแรม</th><th>ที่ตั้ง</th><th>เรตติ้ง</th><th>จัดการ</th></tr></thead>
                <tbody id="tb-hotels"></tbody>
            </table>
        </div>

        <div id="rooms" class="tab-content">
            <div style="background: #f9f9f9; padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #ddd;">
                <h4 id="r-title" style="margin-top:0; color:var(--primary);">➕ เพิ่ม/แก้ไข ห้องพัก</h4>
                <input type="hidden" id="edit-r-id">
                <div class="form-row">
                    <select id="r-hotel"></select>
                    <input type="text" id="r-name" placeholder="ชื่อ/เลขห้อง (เช่น 109, A1)">
                    <select id="r-type"><option value="Standard">Standard</option><option value="Deluxe">Deluxe</option><option value="Suite">Suite</option></select>
                </div>
                <div class="form-row"><input type="number" id="r-price" placeholder="ราคาต่อคืน"><input type="number" id="r-occ" placeholder="เข้าพักได้กี่คน"></div>
                <button class="btn btn-success" id="btn-save-r" onclick="saveRoom()">บันทึกห้องพัก</button>
                <button class="btn" style="display:none; background:#666;" id="btn-cancel-r" onclick="resetRoomForm()">ยกเลิกการแก้ไข</button>
            </div>
            
            <h4 style="margin-bottom: 10px;">เลือกดูห้องตามโรงแรม:</h4>
            <select id="filter-hotel" onchange="renderRooms()" style="padding:10px; margin-bottom:15px; width:100%; max-width:400px; border:1px solid #ccc; border-radius:4px;"></select>
            
            <table>
                <thead><tr><th>ชื่อโรงแรม</th><th>ชื่อ/เลขห้อง</th><th>ประเภทห้อง</th><th>ราคา</th><th>พักได้</th><th>จัดการ</th></tr></thead>
                <tbody id="tb-rooms"></tbody>
            </table>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('token');
        if (localStorage.getItem('role') !== 'พนักงาน') window.location.href = '/';
        const headers = { headers: { Authorization: `Bearer ${token}` } };
        let allData = [];

        function switchTab(t, btn) {
            document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
            document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
            document.getElementById(t).style.display = 'block'; btn.classList.add('active');
        }

        async function loadData() {
            try {
                const resB = await axios.get('http://localhost:3000/api/admin/bookings', headers);
                document.getElementById('tb-bookings').innerHTML = resB.data.map(b => {
                    const badge = b.status === 'Pending' ? 'bg-pending' : (b.status === 'Confirmed' ? 'bg-confirmed' : 'bg-cancelled');
                    const thaiStatus = b.status === 'Pending' ? 'รอดำเนินการ' : b.status;
                    return `
                    <tr><td>#${b.booking_id}</td><td>${b.User.username}</td><td>${b.Room.Hotel.hotel_name} <br><small>(ห้อง: ${b.Room.room_name} - ${b.Room.room_type})</small></td><td>${b.check_in_date} <br>ถึง ${b.check_out_date}</td>
                    <td style="color:#008009; font-weight:bold;">${b.total_amount.toLocaleString()} ฿</td>
                    <td><span class="badge ${badge}">${thaiStatus}</span></td>
                    <td>
                        <select id="s-${b.booking_id}">
                            <option value="Pending" ${b.status==='Pending'?'selected':''}>รอดำเนินการ</option>
                            <option value="Confirmed" ${b.status==='Confirmed'?'selected':''}>ยืนยันแล้ว</option>
                            <option value="Cancelled" ${b.status==='Cancelled'?'selected':''}>ยกเลิก</option>
                        </select>
                        <button class="btn" style="padding:5px;" onclick="updStat(${b.booking_id})">บันทึก</button>
                    </td></tr>
                `}).join('');

                const resH = await axios.get('http://localhost:3000/api/admin/all-data', headers);
                allData = resH.data;
                
                document.getElementById('tb-hotels').innerHTML = allData.map(h => `<tr><td>${h.hotel_id}</td><td>${h.hotel_name}</td><td>${h.location}</td><td>${h.rating}</td><td><button class="btn" style="background:#febb02; color:black;" onclick="editHotel(${h.hotel_id})">แก้ไข</button> <button class="btn btn-danger" onclick="delHotel(${h.hotel_id})">ลบ</button></td></tr>`).join('');
                
                const opt = allData.map(h => `<option value="${h.hotel_id}">${h.hotel_name}</option>`).join('');
                document.getElementById('r-hotel').innerHTML = opt;
                document.getElementById('filter-hotel').innerHTML = '<option value="all">ดูทุกโรงแรม</option>' + opt;
                
                renderRooms();
            } catch (e) { alert('Session หมดอายุ'); window.location.href='/login'; }
        }

        async function updStat(id) {
            await axios.put(`http://localhost:3000/api/admin/bookings/${id}`, { status: document.getElementById(`s-${id}`).value }, headers);
            alert('อัปเดตสถานะสำเร็จ'); loadData();
        }

        function editHotel(id) {
            const h = allData.find(x => x.hotel_id === id);
            document.getElementById('edit-h-id').value = id; document.getElementById('h-name').value = h.hotel_name;
            document.getElementById('h-loc').value = h.location; document.getElementById('h-rating').value = h.rating;
            document.getElementById('h-desc').value = h.description; document.getElementById('h-img').value = h.image_url;
            document.getElementById('h-title').innerText = '✏️ แก้ไขโรงแรม'; document.getElementById('btn-save-h').innerText = 'อัปเดต';
            document.getElementById('btn-cancel-h').style.display = 'inline-block';
        }
        function resetHotelForm() {
            document.getElementById('edit-h-id').value = ''; document.getElementById('h-name').value = '';
            document.getElementById('h-loc').value = ''; document.getElementById('h-rating').value = '';
            document.getElementById('h-desc').value = ''; document.getElementById('h-img').value = '';
            document.getElementById('h-title').innerText = '➕ เพิ่มโรงแรมใหม่'; document.getElementById('btn-save-h').innerText = 'บันทึกโรงแรม';
            document.getElementById('btn-cancel-h').style.display = 'none';
        }
        async function saveHotel() {
            const id = document.getElementById('edit-h-id').value;
            const data = { hotel_name: document.getElementById('h-name').value, location: document.getElementById('h-loc').value, rating: document.getElementById('h-rating').value, description: document.getElementById('h-desc').value, image_url: document.getElementById('h-img').value };
            if(id) await axios.put(`http://localhost:3000/api/admin/hotels/${id}`, data, headers);
            else await axios.post('http://localhost:3000/api/admin/hotels', data, headers);
            alert('บันทึกสำเร็จ!'); resetHotelForm(); loadData();
        }
        async function delHotel(id) { if(confirm('ลบโรงแรมนี้?')) { try { await axios.delete(`http://localhost:3000/api/admin/hotels/${id}`, headers); loadData(); } catch(e) { alert(e.response.data.error); } } }

        function renderRooms() {
            const filterId = document.getElementById('filter-hotel').value;
            let html = '';
            allData.forEach(h => {
                if(filterId === 'all' || filterId == h.hotel_id) {
                    h.Rooms.forEach(r => {
                        html += `<tr><td><b>${h.hotel_name}</b></td><td>${r.room_name}</td><td>${r.room_type}</td><td>${r.price_per_night}</td><td>${r.max_occupancy}</td><td><button class="btn" style="background:#febb02; color:black;" onclick="editRoom(${h.hotel_id}, ${r.room_id})">แก้ไข</button> <button class="btn btn-danger" onclick="delRoom(${r.room_id})">ลบ</button></td></tr>`;
                    });
                }
            });
            document.getElementById('tb-rooms').innerHTML = html;
        }

        function editRoom(hId, rId) {
            const r = allData.find(x => x.hotel_id === hId).Rooms.find(x => x.room_id === rId);
            document.getElementById('edit-r-id').value = rId; document.getElementById('r-hotel').value = hId;
            document.getElementById('r-name').value = r.room_name; document.getElementById('r-type').value = r.room_type;
            document.getElementById('r-price').value = r.price_per_night; document.getElementById('r-occ').value = r.max_occupancy;
            document.getElementById('r-title').innerText = '✏️ แก้ไขห้องพัก'; document.getElementById('btn-save-r').innerText = 'อัปเดต';
            document.getElementById('btn-cancel-r').style.display = 'inline-block';
        }
        function resetRoomForm() {
            document.getElementById('edit-r-id').value = ''; document.getElementById('r-name').value = '';
            document.getElementById('r-price').value = ''; document.getElementById('r-occ').value = '';
            document.getElementById('r-title').innerText = '➕ เพิ่มห้องพักใหม่'; document.getElementById('btn-save-r').innerText = 'บันทึกห้องพัก';
            document.getElementById('btn-cancel-r').style.display = 'none';
        }
        async function saveRoom() {
            const id = document.getElementById('edit-r-id').value;
            const data = { hotel_id: document.getElementById('r-hotel').value, room_name: document.getElementById('r-name').value, room_type: document.getElementById('r-type').value, price_per_night: document.getElementById('r-price').value, max_occupancy: document.getElementById('r-occ').value };
            if(id) await axios.put(`http://localhost:3000/api/admin/rooms/${id}`, data, headers);
            else await axios.post('http://localhost:3000/api/admin/rooms', data, headers);
            alert('บันทึกสำเร็จ!'); resetRoomForm(); loadData();
        }
        async function delRoom(id) { if(confirm('ลบห้องพักนี้?')) { try { await axios.delete(`http://localhost:3000/api/admin/rooms/${id}`, headers); loadData(); } catch(e) { alert(e.response.data.error); } } }

        loadData();
    </script>
</body>
</html>