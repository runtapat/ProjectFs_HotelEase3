<%- include('partials/header') %>

<style>
    /* 🌟 1. สไตล์ดั้งเดิมและระบบ Hover แบบนิ่ง (คงไว้ทั้งหมด) */
    .tab-btn { padding: 12px 25px; background: #e0e0e0; border: none; cursor: pointer; font-size: 16px; font-weight: bold; border-radius: 8px 8px 0 0; transition: 0.3s; margin-right: 2px; }
    .tab-btn.active { background: white; color: var(--primary); border: 1px solid #ddd; border-bottom: none; }
    .tab-content { display: none; background: white; padding: 25px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); border-radius: 0 8px 8px 8px; border: 1px solid #ddd; }

    .tab-group-label { font-size: 12px; color: #888; text-transform: uppercase; margin-bottom: 5px; margin-left: 5px; font-weight: bold; margin-top: 10px; }
    .report-filter-bar { background: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 20px; display: flex; align-items: center; gap: 15px; border: 1px solid #eee; }
    .report-filter-bar label { font-weight: bold; color: var(--primary); }
    
    /* รายงานรายบุคคลเจาะลึก */
    .user-report-card { border: 1px solid #eee; border-radius: 12px; margin-bottom: 30px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
    .user-report-header { background: var(--primary); color: white; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; }
    .sub-table { width: 100%; border-collapse: collapse; background: #fff; }
    .sub-table th { background: #f8f9fa; color: #555; font-size: 12px; padding: 10px; text-align: left; border-bottom: 2px solid #eee; }
    .sub-table td { padding: 12px 10px; border-bottom: 1px solid #f0f0f0; font-size: 14px; }
    .user-report-footer { background: #fff; padding: 15px 20px; text-align: right; border-top: 1px dashed #ddd; font-weight: bold; font-size: 18px; color: #28a745; }

    /* 🌟 2. ตารางและการจัดการ (หัวน้ำเงินตามรูป) */
    .table-responsive { overflow-x: auto; width: 100%; margin-top: 15px; }
    table.data-table { width: 100%; border-collapse: collapse; background: white; }
    table.data-table th { background: #003580; color: white; padding: 12px; text-align: center; font-size: 14px; }
    table.data-table td { padding: 12px; border: 1px solid #eee; font-size: 14px; text-align: center; vertical-align: middle; }
    table.data-table tr:nth-child(even) { background-color: #f9f9f9; }

    .btn, .tab-btn, .btn-save, button { transition: background-color 0.2s ease !important; transform: none !important; box-shadow: none !important; display: inline-block; vertical-align: middle; }
    .tab-btn:hover { background-color: #f5f5f5 !important; color: var(--primary) !important; outline: 1px solid rgba(0,0,0,0.1); }
    .btn-save:hover { background-color: #005999 !important; }
    button[style*="background:#febb02"]:hover { background-color: #e5a900 !important; }
    button[style*="background:#dc3545"]:hover { background-color: #bd2130 !important; }

    .badge { padding: 6px 12px; border-radius: 4px; font-weight: bold; font-size: 12px; display: inline-block; }
    .bg-pending { background: var(--secondary); color: #333; }
    .bg-confirmed { background: #28a745; color: white; }
    .bg-cancelled { background: #dc3545; color: white; }
    .btn-save { background: #0071c2; color: white; border: none; padding: 8px 15px; border-radius: 4px; cursor: pointer; font-weight: bold; }
    .form-row { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 15px; }
    .form-row input, .form-row select { flex: 1; min-width: 200px; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px; }
</style>

<div class="container" style="max-width: 1200px; margin: 30px auto; padding: 0 20px;">
    
    <div style="display: flex; flex-wrap: wrap; align-items: flex-end; gap: 20px; margin-bottom: 0; overflow-x: auto;">
        <div>
            <div class="tab-group-label">📊 Analytics Reports</div>
            <div style="display: flex;">
                <button class="tab-btn active" onclick="switchTab('dashboard', this)">สถิติโรงแรม</button>
                <button class="tab-btn" onclick="switchTab('report-users', this)">รายงานสมาชิก</button>
            </div>
        </div>
        <div style="border-left: 2px solid #ddd; padding-left: 20px;">
            <div class="tab-group-label">🛠️ Data Management</div>
            <div style="display: flex;">
                <button class="tab-btn" onclick="switchTab('bookings', this)">รายการจอง</button>
                <button class="tab-btn" onclick="switchTab('hotels', this)">จัดการโรงแรม</button>
                <button class="tab-btn" onclick="switchTab('rooms', this)">จัดการห้องพัก</button>
            </div>
        </div>
    </div>

    <div id="dashboard" class="tab-content" style="display: block;">
        <h3 style="margin-top: 0; color: var(--primary);">📊 สรุปสถิติและรายได้รายโรงแรม</h3>
        <div class="report-filter-bar">
            <label>🗓️ กรองตามเดือน:</label>
            <input type="month" id="filter-month-db" onchange="renderDashboardAndIncome()">
            <button class="btn" style="padding: 8px 12px; background: #666; color: white;" onclick="document.getElementById('filter-month-db').value=''; renderDashboardAndIncome();">ดูทั้งหมด</button>
        </div>
        <div id="overall-revenue-card" style="background: #f0f8ff; padding: 20px; border-radius: 12px; margin-bottom: 20px; border-left: 5px solid #28a745;"></div>
        <div id="dashboard-summary" class="table-responsive"></div>
    </div>

    <div id="report-users" class="tab-content">
        <h3 style="margin-top: 0; color: var(--primary);">👥 รายงานรายละเอียดการจองรายบุคคล</h3>
        <div class="report-filter-bar">
            <label>🗓️ กรองประวัติตามเดือน:</label>
            <input type="month" id="filter-month-users" onchange="renderUserDetailedReport()">
            <button class="btn" style="padding: 8px 12px; background: #666; color: white;" onclick="document.getElementById('filter-month-users').value=''; renderUserDetailedReport();">ดูทั้งหมด</button>
        </div>
        <div id="users-overall-summary"></div>
        <div id="user-detailed-list"></div>
    </div>

    <div id="bookings" class="tab-content">
        <h3 style="margin-top: 0; color: var(--primary);">📋 รายการจองทั้งหมด (แก้ไขสถานะ)</h3>
        <div class="table-responsive"><table class="data-table"><thead><tr><th>User ID</th><th>ลูกค้า</th><th>โรงแรม (ห้อง)</th><th>วันที่</th><th>ยอดรวม</th><th>สถานะ</th><th>จัดการ</th></tr></thead><tbody id="tb-bookings"></tbody></table></div>
    </div>

    <div id="hotels" class="tab-content">
        <div style="background: #fcfcfc; padding: 20px; border-radius: 8px; margin-bottom: 25px; border: 1px solid #eee;">
            <h4 id="h-title" style="margin-top:0; color:var(--primary);">➕ เพิ่ม/แก้ไข โรงแรม</h4>
            <input type="hidden" id="edit-h-id">
            <div class="form-row">
                <input type="text" id="h-name" placeholder="ชื่อโรงแรม">
                <input type="text" id="h-loc" placeholder="ที่ตั้ง">
            </div>
            <div class="form-row">
                <input type="text" id="h-address" placeholder="ที่อยู่ละเอียด">
                <input type="text" id="h-contact" placeholder="เบอร์โทรศัพท์ติดต่อ">
            </div>
            <div class="form-row">
                <input type="number" step="0.1" id="h-rating" placeholder="เรตติ้ง (0-10)" oninput="if(this.value > 10) this.value = 10; if(this.value < 0) this.value = 0;">
                <input type="text" id="h-img" placeholder="URL รูปภาพ">
            </div>
            <div class="form-row"><input type="text" id="h-desc" placeholder="คำอธิบายโรงแรม" style="flex:1;"></div>
            <button class="btn btn-save" onclick="saveHotel()">บันทึกโรงแรม</button>
            <button class="btn" style="display:none; background:#666; color:white;" id="btn-cancel-h" onclick="resetHotelForm()">ยกเลิก</button>
        </div>
        <div class="table-responsive"><table class="data-table"><thead><tr><th>ID</th><th>ชื่อโรงแรม</th><th>ที่ตั้ง</th><th>เรตติ้ง</th><th>จัดการ</th></tr></thead><tbody id="tb-hotels"></tbody></table></div>
    </div>

    <div id="rooms" class="tab-content">
        <div style="background: #fcfcfc; padding: 20px; border-radius: 8px; margin-bottom: 25px; border: 1px solid #eee;">
            <h4 id="r-title" style="margin-top:0; color:var(--primary);">➕ เพิ่ม/แก้ไข ห้องพัก</h4>
            <input type="hidden" id="edit-r-id">
            <div class="form-row"><select id="r-hotel"></select><input type="text" id="r-name" placeholder="เลขห้อง"><select id="r-type"><option value="Standard">Standard</option><option value="Deluxe">Deluxe</option><option value="Suite">Suite</option></select></div>
            <div class="form-row"><input type="number" id="r-price" placeholder="ราคาต่อคืน"><input type="number" id="r-occ" placeholder="พักได้กี่คน"></div>
            <button class="btn btn-save" onclick="saveRoom()">บันทึกห้องพัก</button>
            <button class="btn" style="display:none; background:#666; color:white;" id="btn-cancel-r" onclick="resetRoomForm()">ยกเลิก</button>
        </div>
        <h4 style="margin-bottom: 10px;">เลือกดูห้องตามโรงแรม:</h4>
        <select id="filter-hotel" onchange="renderRooms()" style="padding:10px; margin-bottom:20px; width:100%; max-width:400px; border:1px solid #ccc; border-radius:4px;"></select>
        <div class="table-responsive">
            <table class="data-table">
                <thead><tr><th>ชื่อโรงแรม</th><th>ชื่อ/เลขห้อง</th><th>ประเภทห้อง</th><th>ราคา</th><th>พักได้</th><th>จัดการ</th></tr></thead>
                <tbody id="tb-rooms"></tbody>
            </table>
        </div>
    </div>
</div>

<script>
    const API_PORT = "<%= apiPort %>"; 
    const API_BASE_URL = `http://localhost:${API_PORT}/api/admin`;
    const token = localStorage.getItem('token');
    if (localStorage.getItem('role') !== 'พนักงาน') window.location.href = '/';
    const authHeader = { headers: { Authorization: `Bearer ${token}` } };
    let allData = [];
    let bookingData = [];

    function switchTab(t, btn) {
        document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
        document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
        document.getElementById(t).style.display = 'block'; btn.classList.add('active');
    }

    async function loadData() {
        try {
            const t = new Date().getTime();
            const resB = await axios.get(`${API_BASE_URL}/bookings?_t=${t}`, authHeader);
            bookingData = resB.data;
            renderBookings();
            renderDashboardAndIncome();
            renderUserDetailedReport();

            const resH = await axios.get(`${API_BASE_URL}/all-data?_t=${t}`, authHeader);
            allData = resH.data;
            document.getElementById('tb-hotels').innerHTML = allData.map(h => `<tr><td>#${h.hotel_id}</td><td style="text-align:left;"><b>${h.hotel_name}</b></td><td>${h.location}</td><td><b style="color:#febb02;">${h.rating}</b> ⭐</td><td><button class="btn-save" style="background:#febb02; color:black; margin-right:5px; padding:6px 12px;" onclick="editHotel(${h.hotel_id})">แก้ไข</button><button class="btn-save" style="background:#dc3545; padding:6px 12px;" onclick="delHotel(${h.hotel_id})">ลบ</button></td></tr>`).join('');
            const opt = allData.map(h => `<option value="${h.hotel_id}">${h.hotel_name}</option>`).join('');
            document.getElementById('r-hotel').innerHTML = opt;
            document.getElementById('filter-hotel').innerHTML = '<option value="all">ดูทุกโรงแรม</option>' + opt;
            renderRooms(); 
        } catch (e) { console.error(e); }
    }

    // 🌟 ระบบสรุปรายได้แบบละเอียด: Confirmed vs Pending
    function renderDashboardAndIncome() {
        const month = document.getElementById('filter-month-db').value;
        const summary = {}; 
        let grandConfirmed = 0; 
        let grandPending = 0;   
        
        const filtered = bookingData.filter(b => !month || b.check_in_date.startsWith(month));
        filtered.forEach(b => {
            const h = b.Room.Hotel.hotel_name;
            if (!summary[h]) summary[h] = { p: 0, c: 0, x: 0, confIncome: 0, pendIncome: 0 };
            
            if (b.status === 'Pending') {
                summary[h].p++;
                summary[h].pendIncome += b.total_amount;
                grandPending += b.total_amount;
            } else if (b.status === 'Confirmed') {
                summary[h].c++;
                summary[h].confIncome += b.total_amount;
                grandConfirmed += b.total_amount;
            } else if (b.status === 'Cancelled') {
                summary[h].x++;
            }
        });

        document.getElementById('overall-revenue-card').innerHTML = `
            <div style="display:flex; flex-direction:column; gap:8px;">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <span>💰 <b>รายได้รวมยืนยันแล้ว (${month || 'ทั้งหมด'}):</b></span>
                    <span style="font-size: 26px; font-weight: bold; color: #28a745;">${grandConfirmed.toLocaleString()} ฿</span>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center; border-top:1px solid #ddd; padding-top:8px;">
                    <span>⏳ <b>ยอดจองรอดำเนินการ:</b></span>
                    <span style="font-size: 18px; font-weight: bold; color: #febb02;">${grandPending.toLocaleString()} ฿</span>
                </div>
            </div>`;

        let html = `<table class="data-table"><thead><tr><th style="text-align:left;">ชื่อโรงแรม</th><th>Pending</th><th>Confirmed</th><th>Cancelled</th><th style="color:#28a745;">รายได้จริง</th><th style="color:#febb02;">รอดำเนินการ</th></tr></thead><tbody>`;
        for (const h in summary) {
            html += `<tr>
                <td style="text-align:left;"><b>${h}</b></td>
                <td>${summary[h].p}</td>
                <td style="color:green; font-weight:bold;">${summary[h].c}</td>
                <td style="color:red;">${summary[h].x}</td>
                <td style="font-weight:bold; color:#28a745;">${summary[h].confIncome.toLocaleString()} ฿</td>
                <td style="font-weight:bold; color:#febb02;">${summary[h].pendIncome.toLocaleString()} ฿</td>
            </tr>`;
        }
        document.getElementById('dashboard-summary').innerHTML = html + `</tbody></table>`;
    }

    // 🌟 ระบบรายงานสมาชิกแยกยอดค้างชำระ
    function renderUserDetailedReport() {
        const month = document.getElementById('filter-month-users').value;
        const userMap = {}; 
        let totalConfSum = 0;
        let totalPendSum = 0;
        
        const filtered = bookingData.filter(b => !month || b.check_in_date.startsWith(month));
        filtered.forEach(b => {
            const n = b.User.username; 
            if (!userMap[n]) userMap[n] = [];
            userMap[n].push(b);
            if (b.status === 'Confirmed') totalConfSum += b.total_amount;
            if (b.status === 'Pending') totalPendSum += b.total_amount;
        });

        document.getElementById('users-overall-summary').innerHTML = `
            <div style="background: #fff9c4; padding: 15px; border-radius: 8px; margin-bottom: 20px; border-left: 5px solid #fbc02d; display: flex; justify-content: space-between; align-items: center; flex-wrap:wrap; gap:10px;">
                <span>👥 <b>จำนวนผู้ใช้:</b> ${Object.keys(userMap).length} คน</span>
                <div style="text-align:right;">
                    <div style="color:#28a745;">✅ <b>ยอดที่ยืนยันแล้ว:</b> <b style="font-size: 20px;">${totalConfSum.toLocaleString()} ฿</b></div>
                    <div style="color:#e5a900; font-size:14px;">⏳ <b>ยอดรอดำเนินการ:</b> <b>${totalPendSum.toLocaleString()} ฿</b></div>
                </div>
            </div>`;

        document.getElementById('user-detailed-list').innerHTML = Object.entries(userMap).map(([name, bks]) => {
            let uConf = 0; let uPend = 0;
            const rows = bks.map(b => { 
                if (b.status === 'Confirmed') uConf += b.total_amount;
                if (b.status === 'Pending') uPend += b.total_amount;
                return `<tr><td>${b.Room.Hotel.hotel_name}</td><td>${b.Room.room_name}</td><td>${b.check_in_date}</td><td>${b.total_amount.toLocaleString()}</td><td>${b.status}</td></tr>`; 
            }).join('');
            return `
                <div class="user-report-card">
                    <div class="user-report-header"><span>👤 <b>${name}</b></span><span>รายการ: ${bks.length}</span></div>
                    <table class="sub-table"><thead><tr><th>โรงแรม</th><th>ห้อง</th><th>วันที่</th><th>ราคา</th><th>สถานะ</th></tr></thead><tbody>${rows}</tbody></table>
                    <div class="user-report-footer">
                        <span style="font-size:14px; color:#666; font-weight:normal; margin-right:15px;">รอดำเนินการ: ${uPend.toLocaleString()} ฿</span>
                        💰 ยอดจริง: ${uConf.toLocaleString()} ฿
                    </div>
                </div>`;
        }).join('');
    }

    // --- ส่วนจัดการข้อมูลโรงแรม (มี Address/Contact) ---
    function editHotel(id) { 
        const h = allData.find(x => x.hotel_id === id); 
        document.getElementById('edit-h-id').value = id; 
        document.getElementById('h-name').value = h.hotel_name; 
        document.getElementById('h-loc').value = h.location; 
        document.getElementById('h-address').value = h.address || '';
        document.getElementById('h-contact').value = h.contact_number || '';
        document.getElementById('h-rating').value = h.rating; 
        document.getElementById('h-desc').value = h.description; 
        document.getElementById('h-img').value = h.image_url; 
        document.getElementById('h-title').innerText = '✏️ แก้ไขโรงแรม'; 
        document.getElementById('btn-cancel-h').style.display = 'inline-block'; 
    }

    function resetHotelForm() { 
        document.getElementById('edit-h-id').value = ''; 
        document.getElementById('h-address').value = '';
        document.getElementById('h-contact').value = '';
        document.getElementById('h-title').innerText = '➕ เพิ่มโรงแรมใหม่'; 
        document.getElementById('btn-cancel-h').style.display = 'none'; 
    }

    async function saveHotel() { 
        const id = document.getElementById('edit-h-id').value; 
        const d = { 
            hotel_name: document.getElementById('h-name').value, 
            location: document.getElementById('h-loc').value, 
            address: document.getElementById('h-address').value,
            contact_number: document.getElementById('h-contact').value,
            rating: document.getElementById('h-rating').value, 
            description: document.getElementById('h-desc').value, 
            image_url: document.getElementById('h-img').value 
        }; 
        try { 
            if(id) await axios.put(`${API_BASE_URL}/hotels/${id}`, d, authHeader); 
            else await axios.post(`${API_BASE_URL}/hotels`, d, authHeader); 
            showFlash('สำเร็จ!', 'success'); 
            resetHotelForm(); 
            loadData(); 
        } catch (e) { showFlash('ล้มเหลว', 'error'); } 
    }

    // --- ส่วน CRUD อื่นๆ คงเดิมตามต้นฉบับ ---
    function renderBookings() { document.getElementById('tb-bookings').innerHTML = bookingData.map(b => { const badge = b.status === 'Pending' ? 'bg-pending' : (b.status === 'Confirmed' ? 'bg-confirmed' : 'bg-cancelled'); return `<tr><td>${b.User.user_id}</td><td style="text-align:left;">${b.User.username}</td><td style="text-align:left;"><b>${b.Room.Hotel.hotel_name}</b><br><small>${b.Room.room_name}</small></td><td>${b.check_in_date}</td><td style="font-weight:bold;">${b.total_amount.toLocaleString()}</td><td><span class="badge ${badge}">${b.status}</span></td><td><div style="display:flex; gap:5px; justify-content:center;"><select id="s-${b.booking_id}" style="padding:5px;" ${b.status==='Cancelled'?'disabled':''}><option value="Pending" ${b.status==='Pending'?'selected':''}>Pending</option><option value="Confirmed" ${b.status==='Confirmed'?'selected':''}>Confirmed</option><option value="Cancelled" ${b.status==='Cancelled'?'selected':''}>Cancelled</option></select><button class="btn-save" onclick="updStat(${b.booking_id})" ${b.status==='Cancelled'?'disabled':''}>บันทึก</button></div></td></tr>`; }).join(''); }
    async function updStat(id) { try { await axios.put(`${API_BASE_URL}/bookings/${id}`, { status: document.getElementById(`s-${id}`).value }, authHeader); showFlash('สำเร็จ!', 'success'); loadData(); } catch (e) { showFlash('ล้มเหลว', 'error'); } }
    function renderRooms() {
        const filterId = document.getElementById('filter-hotel').value;
        let html = '';
        allData.forEach(h => {
            if(filterId === 'all' || filterId == h.hotel_id) {
                h.Rooms.forEach(r => {
                    html += `<tr><td style="text-align:left;"><b>${h.hotel_name}</b></td><td>${r.room_name}</td><td>${r.room_type}</td><td style="font-weight:bold; color:#28a745;">${r.price_per_night.toLocaleString()} ฿</td><td>${r.max_occupancy} คน</td><td><button class="btn-save" style="background:#febb02; color:black; margin-right:5px; padding:6px 12px;" onclick="editRoom(${h.hotel_id}, ${r.room_id})">แก้ไข</button><button class="btn-save" style="background:#dc3545; padding:6px 12px;" onclick="delRoom(${r.room_id})">ลบ</button></td></tr>`;
                });
            }
        });
        document.getElementById('tb-rooms').innerHTML = html;
    }
    async function delHotel(id) { if(confirm('ลบ?')) { try { await axios.delete(`${API_BASE_URL}/hotels/${id}`, authHeader); showFlash('สำเร็จ!', 'success'); loadData(); } catch(e) { showFlash('ล้มเหลว', 'error'); } } }
    function editRoom(hId, rId) { const r = allData.find(x => x.hotel_id === hId).Rooms.find(x => x.room_id === rId); document.getElementById('edit-r-id').value = rId; document.getElementById('r-hotel').value = hId; document.getElementById('r-name').value = r.room_name; document.getElementById('r-type').value = r.room_type; document.getElementById('r-price').value = r.price_per_night; document.getElementById('r-occ').value = r.max_occupancy; document.getElementById('r-title').innerText = '✏️ แก้ไขห้องพัก'; document.getElementById('btn-cancel-r').style.display = 'inline-block'; }
    function resetRoomForm() { document.getElementById('edit-r-id').value = ''; document.getElementById('r-title').innerText = '➕ เพิ่มห้องพักใหม่'; document.getElementById('btn-cancel-r').style.display = 'none'; }
    async function saveRoom() { const id = document.getElementById('edit-r-id').value; const d = { hotel_id: document.getElementById('r-hotel').value, room_name: document.getElementById('r-name').value, room_type: document.getElementById('r-type').value, price_per_night: document.getElementById('r-price').value, max_occupancy: document.getElementById('r-occ').value }; try { if(id) await axios.put(`${API_BASE_URL}/rooms/${id}`, d, authHeader); else await axios.post(`${API_BASE_URL}/rooms`, d, authHeader); showFlash('สำเร็จ!', 'success'); resetRoomForm(); loadData(); } catch (e) { showFlash('ล้มเหลว', 'error'); } }
    async function delRoom(id) { if(confirm('ลบ?')) { try { await axios.delete(`${API_BASE_URL}/rooms/${id}`, authHeader); showFlash('สำเร็จ!', 'success'); loadData(); } catch(e) { showFlash('ล้มเหลว', 'error'); } } }

    loadData();
</script>

