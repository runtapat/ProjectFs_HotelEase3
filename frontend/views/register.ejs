<%- include('partials/header') %>

<div class="container">
    <div class="form-box" style="max-width: 500px;">
        <h2 style="text-align: center; color: var(--primary);">สมัครสมาชิก</h2>
        <input type="text" id="username" placeholder="ชื่อผู้ใช้งาน">
        <input type="email" id="email" placeholder="อีเมล">
        <input type="password" id="pass" placeholder="รหัสผ่าน">
        <input type="text" id="phone" placeholder="เบอร์โทรศัพท์">
        <input type="text" id="address" placeholder="ที่อยู่ (ถ้ามี)">
        <button class="btn" onclick="register()" style="width: 100%;">สร้างบัญชี</button>
        <p style="text-align: center; margin-top: 15px; font-size: 14px;">
            มีบัญชีอยู่แล้ว? <a href="/login" style="color: var(--primary); font-weight: bold;">ไปหน้าล็อกอิน</a>
        </p>
    </div>
</div>

<script>
    async function register() {
        const data = {
            username: document.getElementById('username').value,
            email: document.getElementById('email').value,
            password: document.getElementById('pass').value,
            contact_number: document.getElementById('phone').value,
            address: document.getElementById('address').value
        };

        if(!data.username || !data.email || !data.password) return showFlash('กรุณากรอกข้อมูลสำคัญให้ครบครับ', 'error');

        try {
            await axios.post('http://localhost:3000/api/register', data);
            showFlash('สมัครสมาชิกสำเร็จแล้ว! กรุณาล็อกอินเข้าสู่ระบบ', 'success');
            setTimeout(() => window.location.href = '/login', 1500);
        } catch (e) {
            showFlash(e.response?.data?.error || 'เกิดข้อผิดพลาดในการสมัครสมาชิก', 'error');
        }
    }
</script>

<%- include('partials/footer') %>