<%- include('partials/header') %>

<div class="container" style="max-width: 600px;">
    <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <h2 style="color: var(--primary); border-bottom: 2px solid var(--secondary); padding-bottom: 10px;">ยืนยันการจองห้องพัก</h2>
        
        <div id="booking-summary" style="margin: 25px 0; line-height: 2;">
            <p>กำลังเตรียมข้อมูลการจอง...</p>
        </div>

        <button class="btn" onclick="confirmBooking()" style="width: 100%; font-size: 18px; padding: 15px;">ยืนยันและจองตอนนี้</button>
        <a href="/" style="display: block; text-align: center; margin-top: 15px; color: #666; text-decoration: none;">ยกเลิกและกลับหน้าหลัก</a>
    </div>
</div>

<script>
    // 🌟 ดึงค่า PORT จาก Server ผ่าน EJS Variable
    const API_PORT = "<%= apiPort %>"; 
    const API_URL = `http://localhost:${API_PORT}/api/book`;

    const q = new URLSearchParams(window.location.search);
    const roomId = q.get('id');
    const pricePerNight = parseInt(q.get('price'));
    const inDate = q.get('in');
    const outDate = q.get('out');

    // คำนวณจำนวนคืนและยอดรวม
    const days = Math.ceil(Math.abs(new Date(outDate) - new Date(inDate)) / (1000 * 60 * 60 * 24));
    const total = days * pricePerNight;

    document.getElementById('booking-summary').innerHTML = `
        <p><strong>📅 วันที่เข้าพัก:</strong> ${inDate}</p>
        <p><strong>📅 วันที่เช็คเอาท์:</strong> ${outDate}</p>
        <p><strong>🌙 จำนวน:</strong> ${days} คืน</p>
        <hr>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 15px;">
            <span style="font-size: 18px;">ยอดรวมทั้งสิ้น:</span>
            <span class="price" style="font-size: 28px;">${total.toLocaleString()} ฿</span>
        </div>
    `;

    async function confirmBooking() {
        const token = localStorage.getItem('token');
        if(!token) {
            showFlash('กรุณาเข้าสู่ระบบก่อนทำการจองครับ', 'error');
            return setTimeout(() => window.location.href = '/login', 1500);
        }

        try {
            // 🌟 เปลี่ยน URL มาใช้ตัวแปรที่ดึงค่าจาก .env
            await axios.post(API_URL, {
                room_id: roomId,
                check_in_date: inDate,
                check_out_date: outDate,
                total_amount: total
            }, { headers: { Authorization: `Bearer ${token}` } });

            showFlash('จองห้องพักสำเร็จ! ระบบกำลังพาไปหน้าประวัติการจอง', 'success');
            setTimeout(() => window.location.href = '/my-bookings', 2000);
        } catch (e) {
            showFlash('เกิดข้อผิดพลาดในการจอง กรุณาลองใหม่ครับ', 'error');
        }
    }
</script>

<%- include('partials/footer') %>