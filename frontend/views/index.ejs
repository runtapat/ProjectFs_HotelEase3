<%- include('partials/header') %>

<div class="container" style="max-width: 1200px; margin: 30px auto; padding: 0 20px;">
    <div class="search-bar">
        <input type="text" id="loc" placeholder="ไปที่ไหน? (เช่น Bangkok)">
        <input type="number" id="price" placeholder="งบสูงสุด (บาท)">
        <input type="date" id="in"> <input type="date" id="out">
        <button class="btn" onclick="search()" style="background: #0071c2; color: white; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer; font-weight: bold;">ค้นหาเลย</button>
    </div>
    
    <div id="list" style="margin-top: 20px;"></div>
</div>

<script>
    // 🌟 ดึงค่า PORT จาก Server ผ่าน EJS Variable
    const API_PORT = "<%= apiPort %>"; 
    const API_URL = `http://localhost:${API_PORT}/api/hotels`;

    document.getElementById('in').addEventListener('change', function() {
        document.getElementById('out').min = this.value;
        if(document.getElementById('out').value < this.value) document.getElementById('out').value = this.value;
    });

    async function search() {
        const i = document.getElementById('in').value, o = document.getElementById('out').value;
        if((i && !o) || (!i && o)) return alert('ใส่วันที่ให้ครบครับ');
        if(i && o && i >= o) return alert('วันเช็คเอาท์ต้องอยู่หลังวันเช็คอินครับ');

        const params = { location: document.getElementById('loc').value, max_price: document.getElementById('price').value, check_in: i, check_out: o };
        
        try {
            // 🌟 เปลี่ยน URL มาใช้ตัวแปรที่ดึงค่าจาก .env
            const res = await axios.get(API_URL, { params });
            const list = document.getElementById('list');
            if(!res.data.length) return list.innerHTML = '<h3 style="text-align:center; margin-top:40px;">ไม่พบโรงแรมที่ว่างตามเงื่อนไข</h3>';

            list.innerHTML = res.data.map(h => {
                const minPrice = h.Rooms && h.Rooms.length > 0 ? Math.min(...h.Rooms.map(r => r.price_per_night)) : 0;
                return `
                <div class="hotel-card" style="display:flex; background:white; border-radius:8px; overflow:hidden; margin-bottom:20px; border:1px solid #ddd;">
                    <img src="${h.image_url}" class="hotel-img" alt="hotel" style="width:250px; object-fit:cover;">
                    <div class="hotel-info" style="padding:20px; flex:1; display:flex; justify-content:space-between;">
                        <div>
                            <h2 style="margin:0; color:#0071c2">${h.hotel_name}</h2>
                            <p style="color:#666; margin:5px 0;">📍 ที่ตั้ง: ${h.location}</p>
                            <span class="rating" style="background:#febb02; padding:3px 6px; border-radius:4px; font-weight:bold; font-size:14px;">${h.rating} ⭐</span>
                        </div>
                        <div style="text-align: right; display:flex; flex-direction:column; justify-content:space-between;">
                            <div><span style="font-size:12px; color:#666;">ราคาเริ่มต้น</span><div class="price" style="font-size:24px; font-weight:bold; color:#28a745;">${minPrice.toLocaleString()} ฿</div></div>
                            <button class="btn" onclick="goHotel(${h.hotel_id})" style="background:#0071c2; color:white; border:none; padding:8px 15px; border-radius:4px; cursor:pointer; font-weight:bold; margin-top:10px;">ดูรายละเอียด</button>
                        </div>
                    </div>
                </div>`;
            }).join('');
        } catch (error) {
            console.error("Search Error:", error);
            alert("เกิดข้อผิดพลาดในการค้นหาโรงแรมครับ");
        }
    }

    function goHotel(id) {
        const i = document.getElementById('in').value, o = document.getElementById('out').value;
        window.location.href = `/hotel?id=${id}&in=${i}&out=${o}`;
    }
    
    search();
</script>

<%- include('partials/footer') %>