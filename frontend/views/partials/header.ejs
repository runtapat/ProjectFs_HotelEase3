<!DOCTYPE html>
<html lang="th">
<head>
    <title>HotelEase</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <style>
        /* =========================================
           1. FLASH MESSAGES (เน้นให้เด่นและไม่โดนทับ)
           ========================================= */
        #flash-container { 
            position: fixed; 
            top: 20px; 
            right: 20px; 
            z-index: 10000; 
            display: flex; 
            flex-direction: column; 
            gap: 10px; 
        }
        .flash-msg { 
            padding: 15px 25px; 
            border-radius: 8px; 
            color: white; 
            font-weight: bold; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.3); 
            min-width: 300px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            animation: slideIn 0.3s ease-out forwards;
        }
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        .flash-success { background-color: #28a745; border-left: 8px solid #1e7e34; }
        .flash-error { background-color: #dc3545; border-left: 8px solid #a71d2a; }

        /* =========================================
           2. RESPONSIVE & TABLE (สลับสี + Hover ตามโจทย์)
           ========================================= */
        .table-responsive { overflow-x: auto; width: 100%; margin-top: 15px; }
        
        /* ตารางสลับสีและมี Hover Effect */
        table.data-table { border-collapse: collapse; width: 100%; background: white; }
        table.data-table th { background: var(--primary); color: white; padding: 12px; }
        table.data-table td { padding: 12px; border: 1px solid #ddd; }
        /* สลับสีแถวคู่ */
        table.data-table tr:nth-child(even) { background-color: #f9f9f9; }
        /* Hover Effect */
        table.data-table tr:hover { background-color: #f1f1f1; cursor: pointer; }

        @media (max-width: 768px) {
            .hotel-card { flex-direction: column; }
            .hotel-img { width: 100%; height: 200px; }
            nav { padding: 15px 20px; flex-direction: column; gap: 10px; }
        }
    </style>
</head>
<body style="display: flex; flex-direction: column; min-height: 100vh; margin: 0;">
    
    <div id="flash-container"></div>

    <nav>
        <a href="/" style="margin:0;"><h2 style="margin: 0;">HotelEase</h2></a>
        <div id="auth" style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap;"></div>
    </nav>

    <main style="flex: 1;">

    <script>
        // ฟังก์ชันแจ้งเตือนที่ลูกพี่เรียกใช้ใน admin.ejs
        function showFlash(message, type = 'success') {
            const container = document.getElementById('flash-container');
            if(!container) return;

            const flash = document.createElement('div');
            flash.className = `flash-msg flash-${type}`;
            flash.innerHTML = `
                <span>${type === 'success' ? '✅' : '❌'} ${message}</span>
                <button onclick="this.parentElement.remove()" style="background:none; border:none; color:white; cursor:pointer; font-weight:bold; font-size:18px;">✕</button>
            `;
            container.appendChild(flash);

            setTimeout(() => {
                flash.style.opacity = '0';
                flash.style.transform = 'translateX(100%)';
                flash.style.transition = '0.5s';
                setTimeout(() => flash.remove(), 500);
            }, 3000);
        }

        function renderNav() {
            const u = localStorage.getItem('username');
            const role = localStorage.getItem('role');
            const authDiv = document.getElementById('auth');
            
            if (u) {
                let links = '';
                if (role === 'ลูกค้า') {
                    links += `<a href="/my-bookings" style="background:var(--secondary); color:var(--text); padding:8px 15px; border-radius:4px; font-size:14px;">การจองของฉัน</a>`;
                } else if (role === 'พนักงาน' && window.location.pathname !== '/admin') {
                    links += `<a href="/admin">หน้าจัดการแอดมิน</a>`;
                }

                links += `
                    <span style="font-size:14px;">| สวัสดี ${u}</span>
                    <button onclick="localStorage.clear(); window.location.href='/login'" style="background:#dc3545; color:white; border:none; padding:8px 15px; border-radius:4px; cursor:pointer; font-weight:bold; font-size:14px;">Logout</button>
                `;
                authDiv.innerHTML = links;
            } else {
                authDiv.innerHTML = `<a href="/login">เข้าสู่ระบบ</a><a href="/register" style="background:var(--secondary); color:var(--text); padding:8px 15px; border-radius:4px;">สมัครสมาชิก</a>`;
            }
        }
        renderNav();
    </script>